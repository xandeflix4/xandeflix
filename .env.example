# URL do servidor web local usado pelo app Android durante desenvolvimento.
# Exemplos:
# - USB/ADB reverse: http://127.0.0.1:5173
# - Wi-Fi local: http://SEU_IP_LOCAL:5173
CAPACITOR_DEV_SERVER_URL=""

# Metadata enrichment
VITE_TMDB_API_KEY=""

# Supabase backend persistence
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Proxy hardening (Vercel API /api/proxy)
# Lista de hosts permitidos (CSV). Exemplos: iptv.exemplo.com,*.provedor.tv
PROXY_ALLOWED_HOSTS=""
# Em producao, deixe true para exigir whitelist e bloquear hosts fora da lista.
PROXY_REQUIRE_ALLOWLIST="true"
# Portas permitidas (CSV). Deixe vazio para qualquer porta publica.
PROXY_ALLOWED_PORTS=""
# Origens CORS permitidas (CSV). Exemplos: https://xandeflix.vercel.app,https://admin.xandeflix.com
PROXY_ALLOWED_ORIGINS=""
